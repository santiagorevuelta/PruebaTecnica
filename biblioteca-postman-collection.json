{
  "info": {
    "name": "Biblioteca API",
    "description": "Coleccion de endpoints para el sistema de biblioteca. Usar la variable {{base_url}} y {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token",    "value": "",                          "type": "string" }
  ],
  "item": [
    {
      "name": "Autenticacion",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('token presente', () => pm.expect(json.data.token).to.be.a('string'));",
                  "if (json.data?.token) { pm.collectionVariables.set('token', json.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@biblioteca.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/login"
          },
          "response": [
            {
              "name": "Login exitoso",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login exitoso\",\n  \"data\": {\n    \"token\": \"1|abc123...\",\n    \"user\": { \"id\": 1, \"name\": \"Admin\", \"email\": \"admin@biblioteca.com\" }\n  }\n}"
            },
            {
              "name": "Credenciales incorrectas",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Credenciales incorrectas\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Libros",
      "item": [
        {
          "name": "Listar libros",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('data es array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('meta presente', () => pm.expect(pm.response.json().meta).to.have.property('total'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/libros?per_page=10",
              "query": [
                { "key": "per_page",        "value": "10" },
                { "key": "titulo",          "value": "",   "disabled": true },
                { "key": "anio",            "value": "",   "disabled": true },
                { "key": "autor_id",        "value": "",   "disabled": true },
                { "key": "solo_disponibles","value": "1",  "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Listar libros - filtro titulo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const libros = pm.response.json().data;",
                  "pm.test('Todos contienen el termino buscado', () => {",
                  "  libros.forEach(l => pm.expect(l.titulo.toLowerCase()).to.include('rayuela'.toLowerCase()));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/libros?titulo=rayuela"
          }
        },
        {
          "name": "Ver libro por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.test('Tiene campo titulo', () => pm.expect(data).to.have.property('titulo'));",
                  "pm.test('Tiene autores', () => pm.expect(data.autores).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/libros/1"
          }
        },
        {
          "name": "Ver libro - no encontrado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/libros/99999"
          }
        },
        {
          "name": "Crear libro",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "const data = pm.response.json().data;",
                  "pm.test('Tiene ID asignado', () => pm.expect(data.id).to.be.a('number'));",
                  "if (data?.id) { pm.collectionVariables.set('libro_id_nuevo', data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Libro de prueba Postman\",\n  \"isbn\": \"978-0-00-000001-1\",\n  \"year_publicacion\": 2020,\n  \"numero_paginas\": 200,\n  \"stock_disponible\": 3,\n  \"descripcion\": \"Libro creado desde Postman para testing\",\n  \"autores\": [1]\n}"
            },
            "url": "{{base_url}}/libros"
          }
        },
        {
          "name": "Crear libro - validacion falla",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Tiene errors', () => pm.expect(pm.response.json()).to.have.property('errors'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/libros"
          }
        },
        {
          "name": "Actualizar libro",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stock_disponible\": 10\n}"
            },
            "url": "{{base_url}}/libros/1"
          }
        },
        {
          "name": "Eliminar libro (soft delete)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/libros/{{libro_id_nuevo}}"
          }
        }
      ]
    },
    {
      "name": "Prestamos",
      "item": [
        {
          "name": "Listar prestamos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('data es array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/prestamos?per_page=10",
              "query": [
                { "key": "per_page",   "value": "10" },
                { "key": "estado",     "value": "activo",  "disabled": true },
                { "key": "usuario_id", "value": "1",       "disabled": true },
                { "key": "libro_id",   "value": "1",       "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Listar prestamos - filtro vencidos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const prestamos = pm.response.json().data;",
                  "pm.test('Todos tienen estado vencido', () => {",
                  "  prestamos.forEach(p => pm.expect(p.estado).to.equal('vencido'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/prestamos?estado=vencido"
          }
        },
        {
          "name": "Crear prestamo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "const data = pm.response.json().data;",
                  "pm.test('Estado activo', () => pm.expect(data.estado).to.equal('activo'));",
                  "pm.test('Incluye libro', () => pm.expect(data.libro).to.be.an('object'));",
                  "pm.test('Incluye usuario', () => pm.expect(data.usuario).to.be.an('object'));",
                  "if (data?.id) { pm.collectionVariables.set('prestamo_id_nuevo', data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_usuario\": 1,\n  \"id_libro\": 2,\n  \"fecha_devolucion_estimada\": \"2025-12-31\"\n}"
            },
            "url": "{{base_url}}/prestamos"
          }
        },
        {
          "name": "Crear prestamo - sin stock",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.be.false);",
                  "pm.test('Mensaje de error claro', () => pm.expect(pm.response.json().message).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_usuario\": 1,\n  \"id_libro\": 8,\n  \"fecha_devolucion_estimada\": \"2025-12-31\"\n}"
            },
            "url": "{{base_url}}/prestamos"
          }
        },
        {
          "name": "Devolver prestamo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "const data = pm.response.json().data;",
                  "pm.test('Estado cambia a devuelto', () => pm.expect(data.estado).to.equal('devuelto'));",
                  "pm.test('fecha_devolucion_real no es null', () => pm.expect(data.fecha_devolucion_real).to.not.be.null);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/prestamos/{{prestamo_id_nuevo}}/devolver"
          }
        },
        {
          "name": "Devolver prestamo - ya devuelto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/prestamos/{{prestamo_id_nuevo}}/devolver"
          }
        }
      ]
    },
    {
      "name": "Autores",
      "item": [
        {
          "name": "Listar autores",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('data es array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/autores"
          }
        },
        {
          "name": "Eliminar autor con libros - debe fallar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/autores/1"
          }
        }
      ]
    },
    {
      "name": "Estadisticas",
      "item": [
        {
          "name": "Dashboard stats",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.test('Tiene total_libros', () => pm.expect(data).to.have.property('total_libros'));",
                  "pm.test('Tiene prestamos_activos', () => pm.expect(data).to.have.property('prestamos_activos'));",
                  "pm.test('Tiene prestamos_vencidos', () => pm.expect(data).to.have.property('prestamos_vencidos'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/estadisticas"
          }
        }
      ]
    },
    {
      "name": "Seguridad",
      "item": [
        {
          "name": "Request sin token - debe rechazar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/libros"
          }
        },
        {
          "name": "Request con token invalido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer token_invalido_123" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": "{{base_url}}/libros"
          }
        }
      ]
    }
  ]
}
